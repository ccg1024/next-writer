{
  "compilerOptions": {
    "types": ["@emotion/react/types/css-prop", "reflect-metadata"],
    "jsx": "react-jsx",
    "target": "ES6",
    "lib": ["es6", "DOM"],
    "allowJs": true,
    "module": "commonjs",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "baseUrl": ".",
    "outDir": "dist",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "paths": {
      "*": ["node_modules/*"],
      "_types": ["src/types/types.d.ts"],
      "src/*": ["./src/*"],
      "bin/*": ["./bin/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["src/**/unused/*"]
}

